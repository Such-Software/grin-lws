# grin-lws configuration. Copy to .env and fill in.
#
# PUBLIC-CLEAN: every value below is generic. There are no hostnames, operator
# IPs, or secrets baked into this repo — point it at your own grin node + DB.

# HTTP bind address. Bind to loopback / a private network: the user API is not
# authenticated at this layer (the proxying backend does user auth).
GRINLWS_BIND=127.0.0.1:3480

# Database. Postgres for scale, or a SQLite file for a single operator.
#   DATABASE_URL=postgres://grinlws:grinlws@127.0.0.1:5432/grinlws
DATABASE_URL=sqlite://grin-lws.db

# grin node Foreign API v2 (JSON-RPC): tip, block reads, and broadcast.
GRIN_NODE_URL=http://127.0.0.1:3413/v2/foreign
# Optional basic-auth secret for the node Foreign API (empty = none).
GRIN_NODE_API_SECRET=

# Background scanner tuning: how often it polls for new blocks.
GRINLWS_SCAN_POLL_SECS=15

# Restore-depth bound: how many days behind the tip a newly registered account
# may start scanning from. 0 = unbounded.
GRINLWS_RESTORE_MAX_DEPTH_DAYS=0

# Optional shared bearer that gates the admin API (/list_accounts, /rescan).
# Empty = admin API disabled.
GRINLWS_ADMIN_KEY=

# Log filter.
RUST_LOG=grin_lws=info
